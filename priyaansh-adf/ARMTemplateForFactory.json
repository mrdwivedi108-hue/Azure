			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'linkedserviceadls2'"
		},
		"linked_git_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"linkedserviceadls2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://priyaanshfirststorage.dfs.core.windows.net/"
